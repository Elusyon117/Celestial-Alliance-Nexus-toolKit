+    state.targetBuild = String(payload.targetBuild || state.targetBuild);
+    state.device1 = DEVICES.some(d => d.id === payload.device1) ? payload.device1 : state.device1;
+    state.device2 = DEVICES.some(d => d.id === payload.device2) ? payload.device2 : state.device2;
+    state.slot1 = Number(payload.slot1) === 2 ? 2 : 1;
+    state.slot2 = Number(payload.slot2) === 1 ? 1 : 2;
+    state.actions = BASE_ACTIONS.map(item => ({...item}));
+    (Array.isArray(payload.actions) ? payload.actions : []).forEach(addActionIfMissing);
+    state.mappings = (Array.isArray(payload.mappings) ? payload.mappings : []).filter(validMapping);
+    state.importedXml = typeof payload.importedXml === 'string' ? payload.importedXml : '';
+    syncFields();
+    populateCategories();
+    renderAll();
+    saveSoon();
+    toast('Project restored.');
+  }
+
+  function downloadText(filename,text,type){
+    downloadBlob(filename,new Blob([text],{type:`${type};charset=utf-8`}));
+  }
+
+  function downloadBlob(filename,blob){
+    const url = URL.createObjectURL(blob);
+    const link = document.createElement('a');
+    link.href = url;
+    link.download = filename;
+    document.body.appendChild(link);
+    link.click();
+    link.remove();
+    setTimeout(() => URL.revokeObjectURL(url),1500);
+  }
+
+  function readFile(file,callback){
+    if (!file) return;
+    const reader = new FileReader();
+    reader.onerror = () => toast('The selected file could not be read.');
+    reader.onload = () => {
+      try { callback(String(reader.result || '')); }
+      catch (error) { console.error(error); toast(error.message || 'Import failed.'); }
+    };
+    reader.readAsText(file);
+  }
+
+  function clearMappings(){
+    if (!state.mappings.length) return;
+    if (!confirm('Clear every joystick mapping in this builder project?')) return;
+    state.mappings = [];
+    renderAll();
+    saveSoon();
+    toast('All mappings cleared.');
+  }
+
+  function resetBuilder(){
+    if (!confirm('Reset the Flight Profile Builder and remove its local autosave?')) return;
+    localStorage.removeItem(STORAGE_KEY);
+    state.profileName = 'Celestial-HOSAS';
+    state.targetBuild = 'Alpha 4.8.x';
+    state.device1 = 't16-left';
+    state.device2 = 't16-right';
+    state.slot1 = 1;
+    state.slot2 = 2;
+    state.selectedAction = '';
+    state.actions = BASE_ACTIONS.map(item => ({...item}));
+    state.mappings = [];
+    state.importedXml = '';
+    syncFields();
+    populateCategories();
+    selectAction('');
+    renderAll();
+    toast('Builder reset.');
+  }
+
+  function normalizeSlots(changed){
+    const slot1 = Number($('fpb-slot-1').value);
+    const slot2 = Number($('fpb-slot-2').value);
+    if (slot1 === slot2) {
+      if (changed === 1) $('fpb-slot-2').value = slot1 === 1 ? '2' : '1';
+      else $('fpb-slot-1').value = slot2 === 1 ? '2' : '1';
+    }
+    state.slot1 = Number($('fpb-slot-1').value);
+    state.slot2 = Number($('fpb-slot-2').value);
+    renderSticks();
+    renderSummary();
+    saveSoon();
+  }
+
+  function startTester(){
+    state.testerActive = true;
+    state.testerPrevious.clear();
+    $('fpb-input-tester').classList.add('active');
+    $('fpb-input-status').textContent = 'Waiting for a browser-visible joystick input…';
+    cancelAnimationFrame(state.testerFrame);
+    testerLoop();
+  }
+
+  function stopTester(){
+    state.testerActive = false;
+    cancelAnimationFrame(state.testerFrame);
+    $('fpb-input-tester').classList.remove('active');
+    document.querySelectorAll('#flight-profile-view .fpb-control.dragover').forEach(node => node.classList.remove('dragover'));
+  }
+
+  function testerLoop(){
+    if (!state.testerActive) return;
+    const pads = navigator.getGamepads ? [...navigator.getGamepads()].filter(Boolean) : [];
+    if (!pads.length) {
+      $('fpb-input-status').textContent = 'No Gamepad API device detected. Connect a stick, press a button, then try again.';
+    } else {
+      let eventText = '';
+      pads.slice(0,2).forEach((pad,padIndex) => {
+        const slot = padIndex === 0 ? state.slot1 : state.slot2;
+        pad.buttons.forEach((button,index) => {
+          const key = `${pad.index}:b${index}`;
+          const previous = Number(state.testerPrevious.get(key) || 0);
+          const value = Number(button.value || (button.pressed ? 1 : 0));
+          if (value > .55 && previous <= .55) {
+            const input = `js${slot}_button${index + 1}`;
+            eventText = `${pad.id}: button ${index + 1} → ${input}`;
+            flashControl(input);
+          }
+          state.testerPrevious.set(key,value);
+        });
+        pad.axes.forEach((value,index) => {
+          const key = `${pad.index}:a${index}`;
+          const previous = Number(state.testerPrevious.get(key) || 0);
+          if (Math.abs(value) > .72 && Math.abs(previous) <= .72) {
+            const device = padIndex === 0 ? deviceById(state.device1) : deviceById(state.device2);
+            const axis = device.axes[index];
+            if (axis) {
+              const input = `js${slot}_${axis}`;
+              eventText = `${pad.id}: axis ${index} (${value.toFixed(2)}) → ${input}`;
+              flashControl(input);
+            } else eventText = `${pad.id}: axis ${index} (${value.toFixed(2)}) · no diagram axis assigned`;
+          }
+          state.testerPrevious.set(key,value);
+        });
+      });
+      if (eventText) $('fpb-input-status').textContent = eventText;
+      else $('fpb-input-status').textContent = `${pads.length} device${pads.length === 1 ? '' : 's'} visible · press a button or move an axis`;
+    }
+    state.testerFrame = requestAnimationFrame(testerLoop);
+  }
+
+  function flashControl(input){
+    const node = document.querySelector(`#flight-profile-view .fpb-control[data-input="${CSS.escape(input)}"]`);
+    if (!node) return;
+    node.classList.add('dragover');
+    setTimeout(() => node.classList.remove('dragover'),600);
+    node.scrollIntoView({block:'nearest',behavior:'smooth'});
+  }
+
+  function bindEvents(){
+    $('fpb-profile-name').addEventListener('input',event => { state.profileName = event.target.value; saveSoon(); });
+    $('fpb-target-build').addEventListener('input',event => { state.targetBuild = event.target.value; saveSoon(); });
+    $('fpb-layout-preset').addEventListener('change',event => applyPreset(event.target.value));
+    $('fpb-action-search').addEventListener('input',renderActions);
+    $('fpb-category-filter').addEventListener('change',renderActions);
+    $('fpb-clear-selection').addEventListener('click',() => selectAction(''));
+    $('fpb-clear-mappings').addEventListener('click',clearMappings);
+    $('fpb-add-action').addEventListener('click',addCustomAction);
+    $('fpb-reset-btn').addEventListener('click',resetBuilder);
+
+    $('fpb-device-1').addEventListener('change',event => { state.device1 = event.target.value; renderAll(); saveSoon(); });
+    $('fpb-device-2').addEventListener('change',event => { state.device2 = event.target.value; renderAll(); saveSoon(); });
+    $('fpb-slot-1').addEventListener('change',() => normalizeSlots(1));
+    $('fpb-slot-2').addEventListener('change',() => normalizeSlots(2));
+
+    $('fpb-import-xml-btn').addEventListener('click',() => $('fpb-import-xml').click());
+    $('fpb-import-xml').addEventListener('change',event => { readFile(event.target.files?.[0],importXmlText); event.target.value = ''; });
+    $('fpb-export-xml-btn').addEventListener('click',exportXml);
+    $('fpb-export-image-btn').addEventListener('click',exportProfileImage);
+    $('fpb-import-project-btn').addEventListener('click',() => $('fpb-import-project').click());
+    $('fpb-import-project').addEventListener('change',event => { readFile(event.target.files?.[0],importProjectText); event.target.value = ''; });
+    $('fpb-export-project-btn').addEventListener('click',exportProject);
+
+    $('fpb-test-inputs').addEventListener('click',startTester);
+    $('fpb-stop-inputs').addEventListener('click',stopTester);
+    window.addEventListener('gamepadconnected',event => { if (state.testerActive) $('fpb-input-status').textContent = `Connected: ${event.gamepad.id}`; });
+    window.addEventListener('nexus:viewchange',event => { if (event.detail?.viewId !== 'flight-profile-view') { stopTester(); finishDrag(); } });
+    document.addEventListener('dragend',() => finishDrag());
+    document.addEventListener('keydown',event => { if (event.key === 'Escape') finishDrag(); });
+  }
+
+  function initialize(){
+    if (state.initialized || !$('flight-profile-view')) return;
+    state.initialized = true;
+    loadState();
+    syncFields();
+    populateCategories();
+    bindEvents();
+    selectAction('');
+    renderAll();
+  }
+
+  window.nexusInitializeFlightProfileBuilder = initialize;
+})();
+</script>
+
 </body>
 </html>
 
